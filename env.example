# =============================================================================
# FlowLens AI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# Never commit .env to version control.
# All variables marked (required) must be set for the app to start.
# Variables marked (optional) have safe defaults shown below.
# =============================================================================


# -----------------------------------------------------------------------------
# AI API KEYS
# -----------------------------------------------------------------------------

# Groq — primary inference engine (Llama 3.3 70B)
# Free tier: https://console.groq.com
# (required — unless GEMINI_API_KEY is set)
GROQ_API_KEY=

# Gemini — fallback inference engine (Gemini 2.5 Flash)
# Free tier: https://aistudio.google.com/app/apikey
# (required — unless GROQ_API_KEY is set; recommended to set both)
GEMINI_API_KEY=


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------

# Host the FastAPI backend binds to.
# Use 127.0.0.1 for local-only access (recommended for dev).
# Use 0.0.0.0 to expose on the network (required for Docker / remote access).
# (optional — default: 127.0.0.1)
BACKEND_HOST=127.0.0.1

# Port the FastAPI backend listens on.
# (optional — default: 8000)
BACKEND_PORT=8000

# Port the React dev server listens on.
# Only used by start.py — React itself reads REACT_APP_PORT or defaults to 3000.
# (optional — default: 3000)
FRONTEND_PORT=3000

# Base URL the React frontend uses to call the backend API.
# Change this if you deploy the backend to a different host or port.
# React requires all custom env vars to be prefixed with REACT_APP_.
# (optional — default: http://127.0.0.1:8000)
REACT_APP_API_BASE=http://127.0.0.1:8000

# Allowed CORS origins — comma-separated list of URLs that can call the API.
# Must include your frontend origin exactly (no trailing slash).
# (optional — default: http://localhost:3000)
CORS_ORIGINS=http://localhost:3000

# Environment label — controls logging verbosity and error detail in responses.
# Values: development | production
# (optional — default: development)
APP_ENV=development


# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------

# Secret key used for signing tokens / session data if auth is added later.
# Generate a strong value with: python -c "import secrets; print(secrets.token_hex(32))"
# (optional now — required if you add authentication)
SECRET_KEY=change-me-generate-a-real-secret-before-deploying

# Maximum upload file size in bytes.
# Default is 5 MB (5242880). Increase carefully — large files slow parsing.
# (optional — default: 5242880)
MAX_FILE_SIZE_BYTES=5242880

# Comma-separated list of allowed file extensions for upload.
# (optional — default: .txt,.csv)
ALLOWED_EXTENSIONS=.txt,.csv


# -----------------------------------------------------------------------------
# RATE LIMITING (optional — for production deployments behind a public endpoint)
# NOTE: These are scaffolded for future implementation. They are documented
#       here so they are ready to wire in without changing the .env contract.
# -----------------------------------------------------------------------------

# Maximum number of /analyze requests per IP per minute.
# Set to 0 to disable rate limiting entirely.
# (optional — default: 0 — disabled)
RATE_LIMIT_ANALYZE_PER_MINUTE=0

# Maximum number of /chat-groq requests per IP per minute.
# (optional — default: 0 — disabled)
RATE_LIMIT_CHAT_PER_MINUTE=0


# -----------------------------------------------------------------------------
# LOGGING
# NOTE: Scaffolded for future use — wire into uvicorn's --log-level flag
#       or a logging config dict in main.py when you add structured logging.
# -----------------------------------------------------------------------------

# Log level for the FastAPI / Uvicorn backend.
# Values: debug | info | warning | error | critical
# (optional — default: info)
LOG_LEVEL=info

# Log format — json is recommended for production (structured, machine-parseable).
# Values: text | json
# (optional — default: text)
LOG_FORMAT=text


# -----------------------------------------------------------------------------
# AI MODEL OVERRIDES (optional)
# -----------------------------------------------------------------------------

# Override the primary Groq model used for analysis and SOP generation.
# Supported models: llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768
# (optional — default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Override the fast fallback Groq model used on rate-limit (429) responses.
# (optional — default: llama-3.1-8b-instant)
GROQ_MODEL_FAST=llama-3.1-8b-instant

# Override the Gemini model used for fallback inference and SOP generation.
# (optional — default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash


# -----------------------------------------------------------------------------
# FINANCIAL MODEL DEFAULTS
# These are the default cost parameters used in the What-If simulator.
# Users can override them at runtime via the Cost Config panel in the UI.
# -----------------------------------------------------------------------------

# Fully-loaded hourly labor cost per employee (₹/hour).
# (optional — default: 500)
DEFAULT_HOURLY_LABOR_COST=500

# Financial penalty applied per SLA breach event (₹/breach).
# (optional — default: 5000)
DEFAULT_SLA_BREACH_PENALTY=5000

# Daily cost of capital as a decimal fraction of invoice value.
# 0.0005 = 0.05% per day (~18% annualised).
# (optional — default: 0.0005)
DEFAULT_COST_OF_CAPITAL_DAILY=0.0005


# =============================================================================
# QUICK-START CHECKLIST
# =============================================================================
# [ ] Copy this file to .env
# [ ] Set GROQ_API_KEY   (get free key at console.groq.com)
# [ ] Set GEMINI_API_KEY (get free key at aistudio.google.com)
# [ ] Run: python start.py
# =============================================================================
